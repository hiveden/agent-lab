{
  "name": "@agent-lab/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev -p 8788 -H 127.0.0.1",
    "build": "next build",
    "pages:build": "next-on-pages",
    "preview": "pnpm pages:build && wrangler pages dev .vercel/output/static --compatibility-date=2025-04-01 --compatibility-flag=nodejs_compat --port 8788",
    "deploy": "pnpm pages:build && wrangler pages deploy .vercel/output/static",
    "db:init": "bash scripts/init-local-db.sh",
    "db:query": "wrangler d1 execute agent-lab-dev --local --command",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.52",

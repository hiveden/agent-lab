# ===== LLM =====
LLM_PROVIDER=glm
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL_PUSH=glm-4-flash
LLM_MODEL_CHAT=glm-4.6
LLM_MODEL_TOOL=glm-4.6

# ===== Platform API =====
# Agent → Next.js 写入时用的 Bearer token
RADAR_WRITE_TOKEN=
PLATFORM_API_BASE=https://agents.your-domain.com

# ===== Cloudflare D1 (apps/web) =====
# database_id 可入 wrangler.toml 不算秘密
# 但任何 API token 用 `wrangler secret put` 存,不写这里

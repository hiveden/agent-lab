# =====================================================================
# agent-lab 环境变量模板
# 复制为 .env.local (前端) 和 agents/radar/.env (Agent),不进 git
# =====================================================================

# ===== LLM Provider =====
# Phase 1 (本地 mock): LLM_MOCK=1
# Phase 2 (接 GLM): LLM_MOCK=0 + 填 GLM_API_KEY
LLM_MOCK=1
LLM_PROVIDER=glm
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL_PUSH=glm-4-flash
LLM_MODEL_CHAT=glm-4.6
LLM_MODEL_TOOL=glm-4.6

# ===== Platform API (Next.js) =====
# Bearer token,Agent 写入 /api/items/batch 时校验
RADAR_WRITE_TOKEN=dev-radar-token-change-me
# Agent 调用平台 API 的 base URL
PLATFORM_API_BASE=http://127.0.0.1:8788
# 写死的单用户 id (MVP 阶段)
DEFAULT_USER_ID=default_user

# ===== Agent 服务 (FastAPI) =====
# Next.js 转发对话请求到 Agent 的 URL
RADAR_AGENT_BASE=http://127.0.0.1:8001
RADAR_AGENT_PORT=8001

# ===== LangSmith (LLM 可观测性) =====
# 零代码侵入: 设置以下环境变量后 LangChain 自动追踪 LLM 调用
# 获取 API Key: https://smith.langchain.com/settings
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=radar
LANGSMITH_TRACING=false

# ===== OpenTelemetry (Phase 1: trace_id 透传，无 exporter) =====
# 详见 docs/22-OBSERVABILITY-ENTERPRISE.md ADR-002a / Phase 1
# Phase 4 接 SigNoz/Langfuse 时改 OTEL_TRACES_EXPORTER=otlp + 配 endpoint
OTEL_SERVICE_NAME=radar
OTEL_TRACES_EXPORTER=none
# LangChain async callbacks 默认 background 在 SSE 场景丢事件,强制 sync
# 见 https://langfuse.com/integrations/frameworks/langchain "Background Callbacks" 警告
LANGCHAIN_CALLBACKS_BACKGROUND=false

# ===== 网络 =====
# Agent 拉外网信源时的代理 (本地 ClashX)
HTTPS_PROXY=http://127.0.0.1:7890
HTTP_PROXY=http://127.0.0.1:7890
NO_PROXY=127.0.0.1,localhost

# ===== Cloudflare D1 (apps/web) =====
# database_id 写在 wrangler.toml,不算秘密
# CLOUDFLARE_API_TOKEN 用 `wrangler login` 处理,不写在这
